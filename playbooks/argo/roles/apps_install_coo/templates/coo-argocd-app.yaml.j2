apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ coo_argocd_app_name }}
  namespace: {{ coo_argocd_namespace }}
spec:
  project: {{ coo_argocd_project }}
  source:
    repoURL: {{ coo_git_repo_url }}
    targetRevision: {{ coo_git_repo_revision }}
    path: {{ coo_git_repo_path }}
    directory:
      recurse: true
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ coo_target_namespace }}
  syncPolicy:
{% if coo_argocd_sync_policy == "Automatic" %}
    automated:
      prune: true
      selfHeal: true
{% endif %}
    syncOptions:
      - CreateNamespace=true
      - SkipDryRunOnMissingResource=true
      - ServerSideApply=true
  retry:
    limit: 5
    backoff:
      duration: 30s
      factor: 2
      maxDuration: 3m