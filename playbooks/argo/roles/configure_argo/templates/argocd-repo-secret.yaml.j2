apiVersion: v1
kind: Secret
metadata:
  name: "{{ repo_name }}-repo-secret"
  namespace: openshift-gitops
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  type: git
  url: "{{ repo_url }}"
  project: "{{ argocd_project }}"
  username: "{{ vault_repo_username | default(repo_username) }}"
  password: "{{ vault_repo_password }}"
