apiVersion: argoproj.io/v1alpha1
kind: AppProject
metadata:
  name: "{{ app_project_name }}"
  namespace: openshift-gitops
  labels:
    app.kubernetes.io/instance: openshift-gitops
spec:
  description: "{{ app_project_description }}"
  
  # 1. Where are manifests allowed to come from? (must include every repo used by Applications in this project)
  sourceRepos:
{% for repo in project_source_repos %}
    - "{{ repo }}"
{% endfor %}

  # 2. Where are apps allowed to deploy to? (Local cluster, all namespaces)
  destinations:
    - namespace: '*'
      server: https://kubernetes.default.svc

  # 3. Are apps allowed to create cluster-scoped resources? 
  # (Crucial for ACM and Operators)
  clusterResourceWhitelist:
    - group: '*'
      kind: '*'
